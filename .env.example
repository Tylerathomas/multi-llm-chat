# API keys — copy this file to .env and fill in your own keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=

# --- Model overrides ---------------------------------------------------------
# OpenAI, xAI, and Gemini each have one model knob.
OPENAI_MODEL=gpt-5-mini
XAI_MODEL=grok-3-mini
GEMINI_MODEL=gemini-2.5-flash

# Anthropic is called twice per user prompt: once as the per-card answerer
# and once as the synthesizer that reads all four responses. Splitting these
# lets you put a cheap model on the answerer and a smart model on the
# summary, where the synthesis quality matters more.
#
# Fallback chain: if ANTHROPIC_ANSWER_MODEL / ANTHROPIC_SUMMARY_MODEL aren't
# set, both fall back to ANTHROPIC_MODEL (which itself defaults to
# claude-opus-4-7).
ANTHROPIC_ANSWER_MODEL=claude-haiku-4-5
ANTHROPIC_SUMMARY_MODEL=claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6   # optional fallback for both

# --- Rate limiting -----------------------------------------------------------
# Per-IP cap on /api/ask + /api/retry. Defaults are 5 submits per 3600s (1hr).
# For local dev, set RATE_LIMIT_MAX to something huge to effectively disable it.
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=3600
